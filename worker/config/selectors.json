{
  "_comment": "上游网站 CSS 选择器配置 — 首次部署后需要根据实际网站结构更新",
  "_instructions": "在浏览器 DevTools 中检查对应元素，填入正确的 CSS selector",

  "login": {
    "url": "/#/auth/login",
    "email_input": "input[type='email']",
    "password_input": "input[type='password']",
    "submit_button": "button[type='submit']",
    "success_indicator": "[class*='dashboard']",
    "error_indicator": "[class*='error']"
  },

  "plans": {
    "url": "/#/plan",
    "plan_card": "[class*='plan-card'], [class*='package'], .card",
    "plan_name": "h3, h4, [class*='name'], [class*='title']",
    "plan_price": "[class*='price']",
    "plan_buy_button": "button:has-text('购买'), a:has-text('订阅')"
  },

  "checkout": {
    "confirm_button": "button:has-text('确认'), button:has-text('购买')",
    "submit_button": "button[type='submit'], button:has-text('提交')",
    "success_element": "[class*='success'], [class*='complete']"
  },

  "user_dashboard": {
    "url": "/#/user",
    "subscription_list": "[class*='subscription'], [class*='service']",
    "subscription_link": "a[href*='subscribe'], code, pre",
    "copy_button": "button:has-text('复制'), [class*='copy']"
  }
}